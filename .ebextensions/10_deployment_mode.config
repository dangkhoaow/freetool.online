option_settings:
  # Default: Single Instance Deployment (most cost-effective for t4g.micro)
  aws:elasticbeanstalk:environment:
    EnvironmentType: SingleInstance
    ServiceRole: aws-elasticbeanstalk-service-role
    
  # Instance configuration optimized for t4g.micro
  aws:autoscaling:launchconfiguration:
    InstanceType: t4g.micro
    RootVolumeType: gp3
    RootVolumeSize: 10
    RootVolumeIOPS: 3000
    # SecurityGroups: Elastic Beanstalk will create and manage security groups automatically
    
  # Single instance-specific settings
  aws:autoscaling:asg:
    MinSize: 1
    MaxSize: 1
    Availability Zones: Any
    
  # Enhanced health monitoring for single instance
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced
    HealthCheckSuccessThreshold: Ok
    EnhancedHealthAuthEnabled: true
    
  # Single instance process configuration
  aws:elasticbeanstalk:environment:process:default:
    Port: 3000
    Protocol: HTTP
    HealthCheckPath: "/"
    HealthCheckInterval: 30
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 3
    HealthCheckTimeout: 5
    MatcherHTTPCode: "200"

# Uncomment the sections below to switch to Load Balancer mode:

