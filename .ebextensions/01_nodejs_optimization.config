# CRITICAL: Create swap BEFORE any npm operations for heavy dependencies
commands:
  01_create_swap_immediately:
    command: |
      #!/bin/bash
      set -e
      echo "=== CREATING SWAP SPACE FOR T4G.MICRO BEFORE NPM INSTALL ==="
      
      SWAP_SIZE=1536  # 1.5GB for t4g.micro (1GB RAM + 1.5GB swap = 2.5GB total)
      SWAP_FILE="/swapfile"
      
      # Check if swap already exists
      if ! swapon --show | grep -q "/swapfile"; then
        echo "Creating ${SWAP_SIZE}MB swap file for t4g.micro heavy dependencies..."
        
        # Clean up any existing swap file
        swapoff $SWAP_FILE 2>/dev/null || true
        rm -f $SWAP_FILE 2>/dev/null || true
        
        # Create swap file with fallocate for speed
        if command -v fallocate > /dev/null 2>&1; then
          fallocate -l ${SWAP_SIZE}M $SWAP_FILE
        else
          dd if=/dev/zero of=$SWAP_FILE bs=1M count=$SWAP_SIZE status=progress
        fi
        
        chmod 600 $SWAP_FILE
        mkswap $SWAP_FILE
        swapon $SWAP_FILE
        
        # Add to fstab for persistence
        if ! grep -q "$SWAP_FILE" /etc/fstab; then
          echo "$SWAP_FILE swap swap defaults 0 0" >> /etc/fstab
        fi
        
        echo "Swap created successfully: $(swapon --show)"
      else
        echo "Swap already active: $(swapon --show)"
      fi
      
      # Show memory status
      echo "Memory status after swap setup:"
      free -h
      
      # Set VM parameters optimized for t4g.micro with heavy npm installs
      echo "Configuring VM parameters for t4g.micro heavy dependencies..."
      echo "vm.swappiness=20" > /etc/sysctl.d/99-heavy-deps.conf
      echo "vm.vfs_cache_pressure=50" >> /etc/sysctl.d/99-heavy-deps.conf
      echo "vm.dirty_ratio=15" >> /etc/sysctl.d/99-heavy-deps.conf
      echo "vm.dirty_background_ratio=10" >> /etc/sysctl.d/99-heavy-deps.conf
      sysctl -p /etc/sysctl.d/99-heavy-deps.conf
    ignoreErrors: false

option_settings:
  aws:elasticbeanstalk:application:environment:
    # Memory-optimized settings for t4g.micro with heavy dependencies
    NODE_OPTIONS: "--max-old-space-size=1024"
    NODE_ENV: "production"
    NODE_NO_WARNINGS: "1"
    UV_THREADPOOL_SIZE: "4"
    NODE_DEBUG: ""
    # Optimize npm for heavy dependencies (FFmpeg, TensorFlow, WebLLM)
    NPM_CONFIG_PROGRESS: "false"
    NPM_CONFIG_LOGLEVEL: "error"
    NPM_CONFIG_MAXSOCKETS: "4"
    NPM_CONFIG_FETCH_TIMEOUT: "600000"
    NPM_CONFIG_FETCH_RETRY_MINTIMEOUT: "10000"
    NPM_CONFIG_FETCH_RETRY_MAXTIMEOUT: "60000"
    NPM_CONFIG_PREFER_OFFLINE: "false"
    NPM_CONFIG_AUDIT: "false"
    NPM_CONFIG_FUND: "false"
    # Platform settings
    PORT: "3000"
    # AWS settings for deployment
    AWS_REGION: "us-east-1"
    SWAP_SIZE_MB: "1536"

files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/app-logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/nodejs/nodejs.log

  "/opt/elasticbeanstalk/tasks/taillogs.d/app-logs.conf":
    mode: "000644"  
    owner: root
    group: root
    content: |
      /var/log/nodejs/nodejs.log
