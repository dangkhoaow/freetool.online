option_settings:
  aws:elasticbeanstalk:application:environment:
    # Ensure proper startup configuration for Node.js
    NODE_ENV: "production"
    PORT: "3000"
  
  # Configure the Node.js platform
  aws:elasticbeanstalk:environment:process:default:
    Port: 3000
    Protocol: HTTP
    HealthCheckPath: "/"
    MatcherHTTPCode: "200"
    
files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/nodejs-logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/nodejs/nodejs.log
      /var/app/current/npm-debug.log*
      /var/app/current/yarn-error.log*
      
  "/opt/elasticbeanstalk/tasks/taillogs.d/nodejs-logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/nodejs/nodejs.log
      /var/app/current/npm-debug.log*
      /var/app/current/yarn-error.log*

commands:
  01_create_nodejs_log_dir:
    command: "mkdir -p /var/log/nodejs && chown nodejs:nodejs /var/log/nodejs"
    ignoreErrors: true
    
  02_verify_nodejs_version:
    command: "node --version && npm --version"
    ignoreErrors: true
