files:
  "/opt/elasticbeanstalk/hooks/preinit/01_mount_nvme_early.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Set up NVMe immediately during instance initialization
      # This runs very early, even before any deployment starts
      
      set -e
      echo "====== PRE-INIT: SETTING UP NVME IMMEDIATELY ======"
      
      # Emergency cleanup first thing
      echo "Emergency disk cleanup..."
      rm -rf /tmp/* /var/tmp/* 2>/dev/null || true
      find /var/log -type f -delete 2>/dev/null || true
      
      # Check for NVMe device
      if lsblk | grep -q nvme; then
        echo "NVMe device found, setting up immediately"
        
        # Figure out which NVMe device to use
        NVME_DEVICE=""
        if lsblk | grep -q nvme1n1; then
          NVME_DEVICE="/dev/nvme1n1"
        elif lsblk | grep -q nvme0n1; then
          NVME_DEVICE="/dev/nvme0n1"
        else
          # Get first nvme device
          NVME_DEVICE=$(lsblk | grep nvme | head -n1 | awk '{print $1}')
          NVME_DEVICE="/dev/$NVME_DEVICE"
        fi
        
        echo "Using NVMe device: $NVME_DEVICE"
        
        # Format if needed
        if ! blkid $NVME_DEVICE > /dev/null; then
          echo "Formatting NVMe disk immediately"
          mkfs -t xfs $NVME_DEVICE
        fi
        
        # Create and mount
        NVME_MOUNT="/mnt/nvme_data"
        mkdir -p $NVME_MOUNT
        
        if ! mountpoint -q $NVME_MOUNT; then
          echo "Mounting NVMe disk immediately"
          mount $NVME_DEVICE $NVME_MOUNT
          echo "$NVME_DEVICE $NVME_MOUNT xfs defaults,nofail 0 2" >> /etc/fstab
          
          # Create essential directories
          mkdir -p $NVME_MOUNT/node_modules
          mkdir -p $NVME_MOUNT/npm-cache
          chmod -R 777 $NVME_MOUNT/node_modules
          chmod -R 777 $NVME_MOUNT/npm-cache
        fi
        
        echo "Setting npm to use NVMe for all future operations"
        # Create global npmrc files - line by line to avoid YAML parsing issues
        echo "Creating global npmrc files"
        
        # For /etc/npmrc
        echo "cache=/mnt/nvme_data/npm-cache" > /etc/npmrc
        echo "legacy-peer-deps=true" >> /etc/npmrc
        echo "no-fund=true" >> /etc/npmrc
        echo "loglevel=warn" >> /etc/npmrc
        
        # For root user
        echo "cache=/mnt/nvme_data/npm-cache" > /root/.npmrc
        echo "legacy-peer-deps=true" >> /root/.npmrc
        echo "no-fund=true" >> /root/.npmrc
        echo "loglevel=warn" >> /root/.npmrc
        
        # Set npm config
        npm config set cache $NVME_MOUNT/npm-cache --global
        npm config set legacy-peer-deps true --global
        
        echo "NVMe setup complete during pre-initialization"
      else
        echo "No NVMe device found during pre-initialization"
      fi
      
      # Clean up tmp and log files one more time
      rm -rf /var/log/eb-engine.log
      
      echo "====== PRE-INIT NVME SETUP COMPLETE ======"
      exit 0

commands:
  01_reduce_log_level:
    command: "sed -i 's/LogLevel=.*/LogLevel=warning/' /opt/elasticbeanstalk/containerfiles/ebnode.conf || true"
    ignoreErrors: true
  
  02_reduce_npm_size:
    command: "npm config set --global cache-min 999999999 && npm config set --global production true"
    ignoreErrors: true
    
  03_reset_dir_permissions:
    command: |
      find /var/app -type d -exec chmod 755 {} \; || true
      find /tmp -type d -exec chmod 777 {} \; || true
    ignoreErrors: true
