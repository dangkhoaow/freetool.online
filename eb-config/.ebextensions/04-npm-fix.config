files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/45npm_override.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Override the default npm installation process
      
      echo "====== EB NPM INSTALLER OVERRIDE ======"
      
      # Setting environment variables for npm
      export NPM_CONFIG_LEGACY_PEER_DEPS=true
      
      # Create an npm config file in the webapp user's home
      if [ -d "/home/webapp" ]; then
        cat > /home/webapp/.npmrc <<EOF
      cache=/mnt/nvme_data/npm-cache
      prefer-offline=true
      legacy-peer-deps=true
      EOF
        chown webapp:webapp /home/webapp/.npmrc
      fi
      
      # Create an npm config file in the staging directory
      if [ -d "/var/app/staging" ]; then
        cat > /var/app/staging/.npmrc <<EOF
      cache=/mnt/nvme_data/npm-cache
      prefer-offline=true
      legacy-peer-deps=true
      EOF
        chown webapp:webapp /var/app/staging/.npmrc
      fi
      
      # Create one in root's home too
      cat > /root/.npmrc <<EOF
      cache=/mnt/nvme_data/npm-cache
      prefer-offline=true
      legacy-peer-deps=true
      EOF
      
      # Show current disk space
      echo "Disk space before npm operations:"
      df -h /
      
      # Create NVMe node_modules symlink if needed
      if ! [ -L "/var/app/staging/node_modules" ] && mountpoint -q /mnt/nvme_data; then
        echo "Creating node_modules symlink to NVMe"
        # Remove existing if needed
        if [ -d "/var/app/staging/node_modules" ]; then
          rm -rf /var/app/staging/node_modules
        fi
        # Create the symlink
        ln -sf /mnt/nvme_data/node_modules /var/app/staging/node_modules
        chown -h webapp:webapp /var/app/staging/node_modules
      fi
      
      # Clean npm cache on disk to free space
      echo "Cleaning npm caches..."
      npm cache clean --force
      
      # Set the npm config globally 
      npm config set legacy-peer-deps true --global
      npm config set cache /mnt/nvme_data/npm-cache --global
      
      echo "====== EB NPM INSTALLER OVERRIDE COMPLETE ======"
      exit 0

commands:
  01_ensure_npm_legacy_deps:
    command: "npm config set legacy-peer-deps true"
    ignoreErrors: true
    
  02_clean_npm_cache:
    command: "npm cache clean --force"
    ignoreErrors: true
