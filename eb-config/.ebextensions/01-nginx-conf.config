files:
  "/etc/nginx/conf.d/freetool-web.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Nginx configuration for FreeTool.online
      
      # Upstream node.js server
      upstream nodejs {
        server 127.0.0.1:3000;
        keepalive 256;
      }
      
      # Force proper content types for Next.js files
      map $uri $content_type_by_extension {
        "~\.js$"           "application/javascript";
        "~\.mjs$"          "application/javascript";
        "~\.css$"          "text/css";
        "~\.json$"         "application/json";
        default            "";
      }
      
      # Override content type if needed
      map $sent_http_content_type $fixed_content_type {
        "~text/plain.*js"       "application/javascript";
        "~text/html.*js"        "application/javascript";
        "~application/octet-stream.*js" "application/javascript";
        default                  $sent_http_content_type;
      }
      
      server {
          listen 80;
          server_name localhost;
          
          # Logging
          error_log /var/log/nginx/freetool-error.log debug;
          access_log /var/log/nginx/freetool-access.log combined;
          
          # Log 404 errors for debugging
          log_format missing_log '[$time_local] "$request" - Missing resource';
          access_log /var/log/nginx/404_errors.log missing_log if=$status = 404;
          
          # Set large client body size to allow uploads
          client_max_body_size 500M;
          
          # Critical: Direct pass-through of status codes from Next.js
          proxy_intercept_errors off;
          
          # Enable gzip compression for better performance
          gzip on;
          gzip_comp_level 4;
          gzip_min_length 1000;
          gzip_proxied any;
          gzip_types text/plain text/css application/json application/javascript text/xml application/xml application/xml+rss text/javascript;
          
          # Proper MIME type handling
          include /etc/nginx/mime.types;
          default_type application/octet-stream;
          
          # Use NVMe for nginx cache if available
          proxy_cache_path /mnt/nvme_data/nginx-cache levels=1:2 keys_zone=STATIC:10m inactive=24h max_size=1g;
          
          # Set cache control headers for static assets
          location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
              # Proxy to the Next.js server
              proxy_pass http://nodejs;
              
              # Standard proxy headers
              proxy_http_version 1.1;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add debug headers
              add_header X-Debug-Path $request_uri always;
              
              # Cache settings
              proxy_cache STATIC;
              proxy_cache_valid 200 1y;
              
              # Add cache headers directly for static assets
              expires 7d;
              add_header Cache-Control "public, max-age=604800, immutable" always;
              add_header X-Content-Type-Options nosniff always;
              
              # Manually set content type for JavaScript and CSS files
              if ($request_filename ~* \.js$) {
                  add_header Content-Type "application/javascript" always;
              }
              
              if ($request_filename ~* \.css$) {
                  add_header Content-Type "text/css" always;
              }
          }
          
          # Explicitly handle Next.js JS chunks with correct mime type
          location ~* /_next/static/chunks/.*\.js$ {
              proxy_pass http://nodejs;
              proxy_http_version 1.1;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Explicitly set Content-Type for JavaScript
              add_header Content-Type "application/javascript" always;
              add_header Cache-Control "public, max-age=31536000, immutable" always;
              add_header X-Content-Type-Options nosniff always;
              
              # Cache settings
              proxy_cache STATIC;
              proxy_cache_valid 200 1y;
          }
          
          # Avoid caching _next/data/ requests too long (Next.js data fetching)
          location ~* /_next/data/ {
              proxy_pass http://nodejs;
              proxy_http_version 1.1;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              add_header Cache-Control "public, max-age=30";
          }
          
          # Health check endpoint
          location /health {
              proxy_pass http://nodejs;
              proxy_http_version 1.1;
              proxy_set_header Host $host;
              proxy_cache_bypass $http_upgrade;
          }
          
          # Main location block for all other requests
          location / {
              proxy_pass http://nodejs;
              proxy_http_version 1.1;
              proxy_set_header Upgrade $http_upgrade;
              proxy_set_header Connection 'upgrade';
              proxy_set_header Host $host;
              proxy_cache_bypass $http_upgrade;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # For proper error handling
              proxy_intercept_errors off;
              
              # Add debug headers
              add_header X-Debug-Path $request_uri always;
          }
      }

  "/etc/nginx/conf.d/proxy-buffer.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Increase proxy buffer sizes for large responses
      proxy_buffer_size 128k;
      proxy_buffers 4 256k;
      proxy_busy_buffers_size 256k;
      
      # Increase timeouts for larger file uploads
      proxy_connect_timeout 300s;
      proxy_send_timeout 300s;
      proxy_read_timeout 300s;

commands:
  01_nginx_reload:
    command: "service nginx reload"
    ignoreErrors: true
