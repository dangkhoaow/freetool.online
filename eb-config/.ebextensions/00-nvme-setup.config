files:
  "/usr/local/bin/configure-nvme.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Simple NVMe disk setup
      set -e
      
      echo "====== CONFIGURING NVME STORAGE ======"
      
      # Check if nvme1n1 exists
      if ! lsblk | grep -q nvme1n1; then
        echo "No NVMe disk detected"
        exit 0
      fi
      
      # Format if needed
      if ! blkid /dev/nvme1n1 > /dev/null; then
        echo "Formatting NVMe disk..."
        mkfs -t xfs /dev/nvme1n1
      fi
      
      # Create and mount
      NVME_MOUNT="/mnt/nvme_data"
      mkdir -p $NVME_MOUNT
      
      if ! mountpoint -q $NVME_MOUNT; then
        echo "Mounting NVMe disk to $NVME_MOUNT..."
        mount /dev/nvme1n1 $NVME_MOUNT
        echo "/dev/nvme1n1 $NVME_MOUNT xfs defaults,nofail 0 2" >> /etc/fstab
      fi
      
      # Create node_modules directory on NVMe
      mkdir -p $NVME_MOUNT/node_modules
      chmod 777 $NVME_MOUNT/node_modules
      chown webapp:webapp $NVME_MOUNT/node_modules
      
      # Ensure /var/app/staging exists 
      mkdir -p /var/app/staging
      
      # Create symlink for node_modules before npm install
      if [ -d "/var/app/staging" ] && [ ! -L "/var/app/staging/node_modules" ]; then
        # Remove existing node_modules if it's a directory
        if [ -d "/var/app/staging/node_modules" ]; then
          rm -rf /var/app/staging/node_modules
        fi
        # Create symlink to NVMe
        ln -sf $NVME_MOUNT/node_modules /var/app/staging/node_modules
        echo "Symlinked /var/app/staging/node_modules to $NVME_MOUNT/node_modules"
      fi
      
      # Create npm cache directory
      mkdir -p $NVME_MOUNT/npm-cache
      chmod 777 $NVME_MOUNT/npm-cache
      
      # Configure npm to use NVMe cache
      npm config set cache $NVME_MOUNT/npm-cache
      
      # Create Nginx cache directory
      mkdir -p $NVME_MOUNT/nginx-cache
      chown nginx:nginx $NVME_MOUNT/nginx-cache
      
      # Set up swap - use smaller swap file if disk is constrained
      SWAP_FILE="$NVME_MOUNT/swap.1"
      SWAP_SIZE_MB=1024
      
      if [ ! -f "$SWAP_FILE" ] || ! swapon -s | grep -q "$SWAP_FILE"; then
        echo "Creating ${SWAP_SIZE_MB}MB swap file on NVMe..."
        dd if=/dev/zero of="$SWAP_FILE" bs=1M count=$SWAP_SIZE_MB
        chmod 600 "$SWAP_FILE"
        mkswap "$SWAP_FILE"
        swapon "$SWAP_FILE"
        echo "$SWAP_FILE none swap sw 0 0" >> /etc/fstab
      fi
      
      echo "NVMe configuration complete at $(date)"
      exit 0

commands:
  01_configure_nvme:
    command: "/usr/local/bin/configure-nvme.sh"
    ignoreErrors: true
