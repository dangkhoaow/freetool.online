files:
  "/usr/local/bin/cleanup-disk.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Emergency disk space cleanup script
      
      echo "====== EMERGENCY DISK SPACE CLEANUP ======"
      
      # Display initial disk space
      echo "Initial disk space:"
      df -h /
      
      # Clean npm cache
      echo "Cleaning npm cache..."
      npm cache clean --force
      
      # Clean temporary files
      echo "Cleaning temporary files..."
      find /tmp -type f -not -path "*/\.ssh/*" -mtime +1 -delete 2>/dev/null || true
      find /var/tmp -type f -mtime +1 -delete 2>/dev/null || true
      
      # Clean log files
      echo "Cleaning log files..."
      find /var/log -name "*.gz" -type f -delete 2>/dev/null || true
      find /var/log -name "*.old" -type f -delete 2>/dev/null || true
      find /var/log -type f -size +10M -exec truncate -s 10M {} \; 2>/dev/null || true
      
      # Clean up package manager caches
      if command -v yum >/dev/null 2>&1; then
        echo "Cleaning yum cache..."
        yum clean all
        rm -rf /var/cache/yum
      fi
      
      # Clear system caches
      echo "Clearing system caches..."
      sync
      echo 3 > /proc/sys/vm/drop_caches
      
      # Final disk space
      echo "Final disk space:"
      df -h /
      
      echo "====== DISK CLEANUP COMPLETE ======"
      exit 0

  "/opt/elasticbeanstalk/hooks/appdeploy/pre/00_cleanup_disk.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Run disk cleanup before deployment starts
      /usr/local/bin/cleanup-disk.sh
      exit 0

commands:
  01_initial_cleanup:
    command: "/usr/local/bin/cleanup-disk.sh"
    ignoreErrors: true
