# JWT configuration - MUST match the backend value exactly
JWT_SECRET="projly-jwt-secret-key-123456789"

# Frontend configuration
NEXTAUTH_URL="https://freetool.online"
FRONTEND_URL=${NEXTAUTH_URL}

# API Base URL - Used for all API endpoints
NEXT_PUBLIC_API_URL="https://service.freetool.online"

# Storage configuration
STORAGE_BASE_URL=${NEXT_PUBLIC_API_URL}
STORAGE_LOCAL_URL=${NEXT_PUBLIC_API_URL}/api/files

# Cache configuration
NEXT_PUBLIC_USER_CACHE_EXPIRY_MINUTES=5
NEXT_PUBLIC_USER_ROLE_CACHE_EXPIRY_MINUTES=5
